{
  "Jwt": {
    "Issuer": "LoafNCatting.Api",
    "Audience": "LoafNCatting.Client",
    "AccessTokenMinutes": 30
  },
  "BootstrapAdmin": {
    "Enabled": false
  },
  "PayOS": {
    "ReturnUrl": "http://localhost:5173/orders?payment=success",
    "CancelUrl": "http://localhost:5173/orders?payment=cancelled"
  },
  "Payments": {
    "PendingPaymentExpiryMinutes": 15
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
